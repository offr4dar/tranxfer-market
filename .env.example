# =============================================================================
# TRANXFER MARKET — Environment Variables Template
#
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local — it is blocked by .gitignore and the pre-commit hook.
#
# ── Variable naming rules ────────────────────────────────────────────────────
# EXPO_PUBLIC_*    → Baked into the app bundle. Visible to anyone who
#                    decompiles the .ipa/.apk. ONLY use for values that are
#                    safe to be public (e.g. anon keys, public URLs).
#
# All other vars   → Server-side only (Edge Functions, webhooks). NEVER prefix
#                    with EXPO_PUBLIC_. These are never included in the bundle.
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE — Database, Storage & Edge Functions
# https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------

# Public (safe to expose — anon key only has RLS-restricted access)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
EXPO_PUBLIC_SUPABASE_FUNCTIONS_URL=https://your-project-ref.supabase.co/functions/v1

# Server-side only — bypasses RLS, used by Edge Functions via Supabase Secrets
# Set with: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=<value>
# Only needed locally for DB migrations / admin scripts
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key


# -----------------------------------------------------------------------------
# CLERK — Authentication
# https://dashboard.clerk.com/apps/your-app/api-keys
# -----------------------------------------------------------------------------

# Public (embedded in app — this is expected and safe for Clerk publishable keys)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# Server-side only — used by Edge Functions / webhooks, never in the app bundle
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret


# -----------------------------------------------------------------------------
# MUX — Video Infrastructure
# https://dashboard.mux.com/settings/access-tokens
#
# IMPORTANT: MUX secrets must NEVER go in this file for production.
# Set them as Supabase Secrets so they only exist in Edge Function environments:
#   supabase secrets set MUX_TOKEN_ID=<value>
#   supabase secrets set MUX_TOKEN_SECRET=<value>
#   supabase secrets set MUX_WEBHOOK_SECRET=<value>
# -----------------------------------------------------------------------------
# MUX_TOKEN_ID=your_mux_token_id           ← set via supabase secrets, not here
# MUX_TOKEN_SECRET=your_mux_token_secret   ← set via supabase secrets, not here
# MUX_WEBHOOK_SECRET=your_mux_webhook_secret


# -----------------------------------------------------------------------------
# STRIPE — Payments & Subscriptions (legacy desktop branch — not used in app)
# https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stripe Price / Product IDs
STRIPE_PRICE_CLUB_STARTER=price_your_starter_price_id
STRIPE_PRICE_CLUB_PRO=price_your_pro_price_id
STRIPE_PRICE_CLUB_ELITE=price_your_elite_price_id
STRIPE_PRICE_PLAYER_PREMIUM=price_your_player_premium_id
STRIPE_PRODUCT_CLUB_STARTER=prod_your_starter_product_id
STRIPE_PRODUCT_CLUB_PRO=prod_your_pro_product_id
STRIPE_PRODUCT_CLUB_ELITE=prod_your_elite_product_id
STRIPE_PRODUCT_PLAYER_PREMIUM=prod_your_player_premium_id
STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/p/login/your_portal_link
