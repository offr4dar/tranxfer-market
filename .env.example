# =============================================================================
# TRANXFER MARKET — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# CLERK — Authentication
# Get these from https://dashboard.clerk.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# Clerk redirect URLs (where users land after sign in/up)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Clerk Webhook Secret — from Clerk Dashboard > Webhooks
# Used to verify incoming webhook payloads from Clerk
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret

# -----------------------------------------------------------------------------
# SUPABASE — Database & Storage
# Get these from https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service Role Key — NEVER expose this to the browser (server-side only)
# Used for webhook handlers and admin operations that bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -----------------------------------------------------------------------------
# STRIPE — Payments & Subscriptions
# Get these from https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Stripe Webhook Secret — from Stripe Dashboard > Webhooks
# Used to verify incoming webhook payloads from Stripe
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Stripe Price IDs — create these in your Stripe Dashboard
# Club subscription tiers
STRIPE_PRICE_CLUB_STARTER=price_your_starter_price_id      # e.g. £49/mo
STRIPE_PRICE_CLUB_PRO=price_your_pro_price_id              # e.g. £99/mo
STRIPE_PRICE_CLUB_ELITE=price_your_elite_price_id          # e.g. £199/mo

# Player premium (optional boost)
STRIPE_PRICE_PLAYER_PREMIUM=price_your_player_premium_id   # e.g. £9.99/mo

# Stripe Product IDs (match your products in Stripe Dashboard)
STRIPE_PRODUCT_CLUB_STARTER=prod_your_starter_product_id
STRIPE_PRODUCT_CLUB_PRO=prod_your_pro_product_id
STRIPE_PRODUCT_CLUB_ELITE=prod_your_elite_product_id
STRIPE_PRODUCT_PLAYER_PREMIUM=prod_your_player_premium_id

# Stripe Customer Portal URL — configure in Stripe Dashboard
STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/p/login/your_portal_link

# -----------------------------------------------------------------------------
# UPLOADTHING — File Uploads
# Get these from https://uploadthing.com/dashboard
# -----------------------------------------------------------------------------
UPLOADTHING_SECRET=sk_live_your_uploadthing_secret
UPLOADTHING_APP_ID=your_uploadthing_app_id

# -----------------------------------------------------------------------------
# APP CONFIG
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Tranxfer Market

# Node environment
NODE_ENV=development
